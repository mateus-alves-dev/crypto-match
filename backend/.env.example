# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Database ──────────────────────────────────────────────────────────────────
# In production, injected via SSM / Secrets Manager through Serverless Framework.
# For local dev, point to a local Postgres instance or a dev RDS via SSH tunnel.
DATABASE_URL="postgresql://postgres:password@localhost:5432/crypto_match_dev"

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ─── Security ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── AWS (only needed for SQS workers in Phase 2+) ────────────────────────────
# AWS_REGION=us-east-1
# SQS_NOTIFICATIONS_URL=https://sqs.us-east-1.amazonaws.com/123456789/crypto-match-notifications-dev
